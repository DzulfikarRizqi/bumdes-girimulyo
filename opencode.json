{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "TestSprite": {
      "type": "local",
      "command": ["npx", "@testsprite/testsprite-mcp@latest"],
      "env": {
        "API_KEY": "{env:TESTSPRITE}"
      }
    }
  },
  "lsp": {
    "typescript-server": {
      "command": ["typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"]
    }
  }
}
